# HuggingFace API（無料・簡単）
# 取得方法: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Google Gemini API（オプション）
# GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq API（オプション）
# GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude API（有料・オプション）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web検索API（競合調査・トレンド分析用）
# 優先順位: Brave > Serper > DuckDuckGo（APIキー不要）

# Brave Search API（推奨）
# 無料枠: 月2,000クエリ、related:演算子で類似サイト検索が可能
# 取得方法: https://api-dashboard.search.brave.com/
# BRAVE_API_KEY=your_brave_api_key_here

# Serper API（代替）
# 無料枠: 月2,500クエリ
# 取得方法: https://serper.dev/
# SERPER_API_KEY=your_serper_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Unsplash API (for reference images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
